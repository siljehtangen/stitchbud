generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime? @map("email_verified")
  image            String?
  password         String?
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  projects Project[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum ProjectType {
  KNITTING
  CROCHET
  SEWING
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  FROGGED
}

model Project {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  title       String
  description String?       @db.Text
  type        ProjectType
  status      ProjectStatus @default(PLANNING)
  isPublic    Boolean       @default(false) @map("is_public")
  sharedWith  String[]      @map("shared_with")
  tags        String[]
  notes       String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  images          ProjectImage[]
  files           ProjectFile[]
  knittingDetails KnittingDetails?
  crochetDetails  CrochetDetails?
  sewingDetails   SewingDetails?
  yarns           Yarn[]
  fabrics         Fabric[]
  rowCounter      RowCounter?
  patternGrid     PatternGrid?

  @@map("projects")
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  url       String
  caption   String?
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_images")
}

model ProjectFile {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  url       String
  filename  String
  fileType  String   @map("file_type")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_files")
}

model KnittingDetails {
  id           String   @id @default(cuid())
  projectId    String   @unique @map("project_id")
  needleSizes  String[] @map("needle_sizes")
  isCircular   Boolean  @default(false) @map("is_circular")
  needleLength Int?     @map("needle_length")
  gauge        String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("knitting_details")
}

model CrochetDetails {
  id        String   @id @default(cuid())
  projectId String   @unique @map("project_id")
  hookSizes String[] @map("hook_sizes")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("crochet_details")
}

model SewingDetails {
  id        String @id @default(cuid())
  projectId String @unique @map("project_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("sewing_details")
}

model Yarn {
  id           String  @id @default(cuid())
  projectId    String  @map("project_id")
  name         String
  type         String?
  color        String?
  weightGrams  Float?  @map("weight_grams")
  lengthMeters Float?  @map("length_meters")
  notes        String? @db.Text

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("yarns")
}

model Fabric {
  id         String  @id @default(cuid())
  projectId  String  @map("project_id")
  name       String
  type       String?
  color      String?
  sizeMeters Float?  @map("size_meters")
  notes      String? @db.Text

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("fabrics")
}

model RowCounter {
  id            String @id @default(cuid())
  projectId     String @unique @map("project_id")
  totalRows     Int    @default(0) @map("total_rows")
  currentRow    Int    @default(0) @map("current_row")
  completedSets Int    @default(0) @map("completed_sets")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("row_counters")
}

model PatternGrid {
  id        String @id @default(cuid())
  projectId String @unique @map("project_id")
  rows      Int    @default(10)
  cols      Int    @default(10)
  gridData  Json   @default("{}") @map("grid_data")
  legend    Json   @default("{}")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("pattern_grids")
}
